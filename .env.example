# Docker Environment Variables
# Copy this file to .env and fill in the required values before running docker-compose.

# ─── Required — MUST change before first deploy ───────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string_min_32_chars

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=habitloop
POSTGRES_PASSWORD=habitloop_secret
POSTGRES_DB=habitloop_db
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=4000
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:80
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
