# ═══════════════════════════════════════════════════════════════
#  HabitLoop — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Node ────────────────────────────────────────────────────
node_modules/
.npm
.yarn/
.pnp
.pnp.js

# ─── Environment Variables ───────────────────────────────────
# Keep .env.example, ignore everything else
.env
.env.*
!.env.example
!**/.env.example

# ─── Build Outputs ───────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo

# ─── Vite ────────────────────────────────────────────────────
frontend/.vite/

# ─── Prisma ──────────────────────────────────────────────────
# Keep schema, ignore generated migrations in dev (commit them in prod)
# backend/prisma/migrations/
!backend/prisma/schema.prisma

# ─── Redis ───────────────────────────────────────────────────
dump.rdb

# ─── Docker ──────────────────────────────────────────────────
# Keep docker-compose.yml, ignore overrides with secrets
docker-compose.override.yml
docker-compose.prod.yml

# ─── Coverage & Testing ──────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
.vitest/

# ─── IDE & Editors ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.fleet/
.zed/

# ─── Package Managers ────────────────────────────────────────
yarn.lock
pnpm-lock.yaml
# Uncomment the one you use and ignore the others:
# !package-lock.json

# ─── Temporary Files ─────────────────────────────────────────
tmp/
temp/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettier-cache

# ─── Secrets & Keys ──────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
