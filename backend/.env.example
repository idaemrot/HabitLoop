# ─── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ───────────────────────────────────────────
# Local:      postgresql://USER:PASSWORD@localhost:5432/habitloop_db
# Production: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://habitloop:habitloop_secret@localhost:5432/habitloop_db

# ─── Redis ──────────────────────────────────────────────
# Local:      redis://localhost:6379
# Production: rediss://:PASSWORD@HOST:PORT  ← Upstash TLS URL (set in Render dashboard)
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────
# Render auto-generates these via generateValue: true in render.yaml
# For local dev, set any strong random string (min 16 chars)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────
# Production: set to your Vercel frontend URL, e.g. https://habitloop.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
